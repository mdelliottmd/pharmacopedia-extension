    "GroupPermissions": {
        "user": {
            "pharmacopedia-vote": true,
            "pharmacopedia-comment": true,
            "pharmacopedia-literature-submit": true,
            "pharmacopedia-fr-submit": true
        },
        "provider": {
            "pharmacopedia-effect-as-provider": true,
            "pharmacopedia-literature-submit": true,
            "pharmacopedia-literature-upload": true
        },
        "admin": {
            "pharmacopedia-effect-as-provider": true,
            "pharmacopedia-verify-review": true,
            "pharmacopedia-activity-view": true,
            "pharmacopedia-literature-submit": true,
            "pharmacopedia-literature-upload": true,
            "pharmacopedia-literature-review": true
        },
        "sysop": {
            "pharmacopedia-effect-as-provider": true,
            "pharmacopedia-verify-review": true,
            "pharmacopedia-activity-view": true,
            "pharmacopedia-literature-submit": true,
            "pharmacopedia-literature-upload": true,
            "pharmacopedia-literature-review": true,
            "pharmacopedia-profile-view-others-full": true,
            "pharmacopedia-fr-submit": true,
            "pharmacopedia-fr-view-private": true,
            "pharmacopedia-fr-review": true
        }
    },
    "config": {
        "PharmacopediaVerifyDocsDir": {
            "value": "/var/lib/pharmacopedia-verification",
            "description": "Filesystem path where provider-verification documents are stored. Must be outside the web root and writable by the web server."
        },
        "PharmacopediaLiteratureDir": {
            "value": "/var/lib/pharmacopedia-literature",
            "description": "Filesystem path where user-submitted literature PDFs are stored. Must be outside the web root and writable by the web server."
        },
        "PharmacopediaModeratorEmail": {
            "value": "",
            "description": "If set, sends an email to this address whenever a new literature submission lands in the queue. Leave empty to disable."
        },
        "PharmacopediaInteractionCategoryMarker": {
            "value": "MedCategory",
            "description": "DB-key name of the parent category whose members are valid interaction endpoints. Tag a category like Category:Antidepressants by adding [[Category:MedCategory]] to its page so it appears in the Add-interaction search."
        },
        "PharmacopediaLifeStoryDir": {
            "value": "/var/lib/pharmacopedia-life",
            "description": "Filesystem path where Life Story image attachments are stored. Outside web root, www-data writable."
        },
        "PharmacopediaFeatureRequestDir": {
            "value": "/var/lib/pharmacopedia-feature-requests",
            "description": "Filesystem path where feature-request attachments are stored. Outside web root, mode 700, www-data owned."
        },
        "PharmacopediaAdminKeyDir": {
            "value": "/var/lib/pharmacopedia-adminkeys",
            "description": "Filesystem path holding the server master key for the Administer-to-others feature (Mode B). Outside web root, mode 700, www-data owned, inside open_basedir."
        },
        "PharmacopediaOverlinkedThreshold": {
            "value": 10,
            "description": "Special:Overlinked lists external-wiki pages linked from more than this many distinct local pages. Above this count a term is treated as proven in-scope and a candidate for its own local article."
        },
        "PharmacopediaOverlinkedWikiDomains": {
            "value": [ "en.wikipedia.org", "psychonautwiki.org" ],
            "description": "External-wiki hostnames whose inbound links Special:Overlinked counts. A bare host matches that host and its subdomains. All other external links (citations, agency sites, and so on) are ignored."
        }
    },
